generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum TicketStatus {
  OPEN
  PAID
  VALIDATED
  EXITING
  FINISHED
  CANCELLED
  EVASION
  EXEMPT
}

enum DeviceStatus {
  ONLINE
  OFFLINE
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  username     String          @unique
  passwordHash String
  name         String
  status       UserStatus      @default(ACTIVE)
  unitId       String?
  roleId       String?
  unit         Unit?           @relation(fields: [unitId], references: [id])
  role         Role?           @relation(fields: [roleId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  cashRegisters CashRegister[]
  movements    Movement[]
  systemLogs   SystemLog[]
  unitAccesses UserUnitAccess[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[]
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id])
}

model Unit {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  address          String?
  city             String?
  state            String?
  capacity         Int               @default(0)
  users            User[]
  userAccesses     UserUnitAccess[]
  parkingLots      ParkingLot[]
  priceTables      PriceTable[]
  tickets          Ticket[]
  payments         Payment[]
  cashRegisters    CashRegister[]
  cashTransactions CashTransaction[]
  gates            Gate[]
  cameras          Camera[]
  terminals        Terminal[]
  lprCaptures      LprCapture[]
  agents           Agent[]
  agentDevices     AgentDevice[]
  agentEvents      AgentEvent[]
  syncBatches      SyncBatch[]
  auditOccurrences AuditOccurrence[]
  notifications    Notification[]
  receivables      Receivable[]
  payables         Payable[]
  incidents        Incident[]
  fiscalConfigs    FiscalConfig[]
}

model UserUnitAccess {
  id        String   @id @default(cuid())
  userId    String
  unitId    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  unit      Unit     @relation(fields: [unitId], references: [id])

  @@unique([userId, unitId])
  @@index([unitId])
}

model ParkingLot {
  id         String          @id @default(cuid())
  name       String
  code       String          @unique
  unitId     String
  capacity   Int             @default(0)
  unit       Unit            @relation(fields: [unitId], references: [id])
  sectors    ParkingSector[]
  spots      ParkingSpot[]
  tickets    Ticket[]
}

model ParkingSector {
  id           String        @id @default(cuid())
  name         String
  parkingLotId String
  parkingLot   ParkingLot    @relation(fields: [parkingLotId], references: [id])
  spots        ParkingSpot[]
}

model ParkingSpot {
  id           String         @id @default(cuid())
  code         String
  type         String
  status       String
  parkingLotId String
  sectorId     String?
  parkingLot   ParkingLot     @relation(fields: [parkingLotId], references: [id])
  sector       ParkingSector? @relation(fields: [sectorId], references: [id])
}

model Vehicle {
  id          String    @id @default(cuid())
  plate       String    @unique
  model       String
  color       String?
  brand       String?
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  tickets     Ticket[]
}

model Customer {
  id              String            @id @default(cuid())
  name            String
  document        String?
  email           String?
  phone           String?
  address         String?
  vehicles        Vehicle[]
  tickets         Ticket[]
  monthlyCustomer MonthlyCustomer?
  credentials     Credential[]
  receivables     Receivable[]
}

model MonthlyCustomer {
  id                String     @id @default(cuid())
  customerId        String     @unique
  planName          String
  contractedSpots   Int        @default(1)
  monthlyFee        Decimal    @db.Decimal(10, 2)
  dueDay            Int
  status            String
  concurrentLimit   Int        @default(1)
  customer          Customer   @relation(fields: [customerId], references: [id])
}

model Credential {
  id            String    @id @default(cuid())
  customerId    String?
  plate         String
  type          String
  validUntil    DateTime?
  allowedDays   Json?
  allowedHours  Json?
  status        String
  customer      Customer? @relation(fields: [customerId], references: [id])
}

model Partner {
  id            String        @id @default(cuid())
  name          String
  document      String?
  type          String
  virtualSeals  VirtualSeal[]
}

model VirtualSeal {
  id           String    @id @default(cuid())
  partnerId    String?
  code         String    @unique
  qrCode       String?
  discountType String
  value        Decimal   @db.Decimal(10, 2)
  validUntil   DateTime?
  usageLimit   Int       @default(1)
  usedCount    Int       @default(0)
  partner      Partner?  @relation(fields: [partnerId], references: [id])
}

model PriceTable {
  id           String      @id @default(cuid())
  unitId       String?
  name         String
  type         String
  active       Boolean     @default(true)
  graceMinutes Int         @default(0)
  maxDaily     Decimal?    @db.Decimal(10, 2)
  unit         Unit?       @relation(fields: [unitId], references: [id])
  rules        PriceRule[]
  tickets      Ticket[]
}

model PriceRule {
  id           String      @id @default(cuid())
  priceTableId String
  name         String
  ruleType     String
  value        Decimal     @db.Decimal(10, 2)
  metadata     Json?
  priceTable   PriceTable  @relation(fields: [priceTableId], references: [id])
}

model Ticket {
  id              String        @id @default(cuid())
  code            String        @unique
  unitId          String?
  status          TicketStatus  @default(OPEN)
  customerId      String?
  vehicleId       String?
  parkingLotId    String?
  priceTableId    String?
  entryAt         DateTime
  exitAt          DateTime?
  expectedAmount  Decimal?      @db.Decimal(10, 2)
  finalAmount     Decimal?      @db.Decimal(10, 2)
  paymentDeadline DateTime?
  origin          String?
  qrCode          String?       @unique
  notes           String?
  unit            Unit?         @relation(fields: [unitId], references: [id])
  customer        Customer?     @relation(fields: [customerId], references: [id])
  vehicle         Vehicle?      @relation(fields: [vehicleId], references: [id])
  parkingLot      ParkingLot?   @relation(fields: [parkingLotId], references: [id])
  priceTable      PriceTable?   @relation(fields: [priceTableId], references: [id])
  images          TicketImage[]
  movements       Movement[]
  payments        Payment[]
  lprCaptures     LprCapture[]

  @@index([unitId, status])
  @@index([vehicleId, status])
}

model TicketImage {
  id        String   @id @default(cuid())
  ticketId  String
  kind      String
  imageUrl  String
  metadata  Json?
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
}

model Movement {
  id        String   @id @default(cuid())
  ticketId   String
  userId    String?
  type      String
  payload   Json?
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Payment {
  id          String   @id @default(cuid())
  ticketId    String?
  unitId      String?
  method      String
  amount      Decimal  @db.Decimal(10, 2)
  status      String
  reference   String?
  origin      String?
  paidAt      DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  ticket      Ticket?  @relation(fields: [ticketId], references: [id])
  unit        Unit?    @relation(fields: [unitId], references: [id])

  @@index([unitId, createdAt])
}

model CashRegister {
  id          String            @id @default(cuid())
  unitId      String
  userId      String?
  code        String            @unique
  status      String
  openedAt    DateTime?
  closedAt    DateTime?
  openingFund Decimal?          @db.Decimal(10, 2)
  unit        Unit              @relation(fields: [unitId], references: [id])
  user        User?             @relation(fields: [userId], references: [id])
  transactions CashTransaction[]
}

model CashTransaction {
  id             String        @id @default(cuid())
  cashRegisterId String
  unitId         String?
  type           String
  amount         Decimal       @db.Decimal(10, 2)
  reason         String?
  createdAt      DateTime      @default(now())
  cashRegister   CashRegister  @relation(fields: [cashRegisterId], references: [id])
  unit           Unit?         @relation(fields: [unitId], references: [id])

  @@index([unitId, createdAt])
}

model Gate {
  id         String       @id @default(cuid())
  unitId     String
  name       String
  type       String
  ip         String?
  status     DeviceStatus @default(ONLINE)
  unit       Unit         @relation(fields: [unitId], references: [id])
}

model Camera {
  id         String       @id @default(cuid())
  unitId     String
  name       String
  type       String
  ip         String?
  status     DeviceStatus @default(ONLINE)
  unit       Unit         @relation(fields: [unitId], references: [id])
  captures   LprCapture[]
}

model Terminal {
  id         String       @id @default(cuid())
  unitId     String
  name       String
  type       String
  ip         String?
  status     DeviceStatus @default(ONLINE)
  unit       Unit         @relation(fields: [unitId], references: [id])
}

model LprCapture {
  id         String    @id @default(cuid())
  ticketId   String?
  cameraId   String?
  unitId     String?
  plate      String
  confidence Decimal   @db.Decimal(5, 2)
  direction  String
  status     String
  imageUrl   String?
  createdAt  DateTime  @default(now())
  ticket     Ticket?   @relation(fields: [ticketId], references: [id])
  camera     Camera?   @relation(fields: [cameraId], references: [id])
  unit       Unit?     @relation(fields: [unitId], references: [id])

  @@index([unitId, createdAt])
  @@index([plate, createdAt])
}

model Agent {
  id           String        @id @default(cuid())
  unitId       String
  name         String
  agentKeyHash String
  status       String
  version      String?
  lastSeenAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  unit         Unit          @relation(fields: [unitId], references: [id])
  devices      AgentDevice[]
  events       AgentEvent[]
  syncBatches  SyncBatch[]

  @@unique([unitId, name])
  @@index([unitId, status])
}

model AgentDevice {
  id                 String      @id @default(cuid())
  agentId            String
  unitId             String
  deviceType         String
  name               String
  externalIdentifier String
  status             String
  lastSignalAt       DateTime?
  metadata           Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  agent              Agent       @relation(fields: [agentId], references: [id])
  unit               Unit        @relation(fields: [unitId], references: [id])
  events             AgentEvent[]

  @@unique([agentId, externalIdentifier])
  @@index([unitId, status])
}

model AgentEvent {
  id               String       @id @default(cuid())
  eventId          String       @unique
  agentId          String
  unitId           String
  agentDeviceId    String?
  eventType        String
  occurredAt       DateTime
  payload          Json
  processingStatus String
  processedAt      DateTime?
  createdAt        DateTime     @default(now())
  agent            Agent        @relation(fields: [agentId], references: [id])
  unit             Unit         @relation(fields: [unitId], references: [id])
  agentDevice      AgentDevice? @relation(fields: [agentDeviceId], references: [id])
  syncBatchItems   SyncBatchItem[]

  @@index([unitId, eventType, occurredAt])
  @@index([agentId, processingStatus])
}

model SyncBatch {
  id          String          @id @default(cuid())
  batchId     String
  agentId     String
  unitId      String
  sentAt      DateTime
  processedAt DateTime?
  status      String
  createdAt   DateTime        @default(now())
  agent       Agent           @relation(fields: [agentId], references: [id])
  unit        Unit            @relation(fields: [unitId], references: [id])
  items       SyncBatchItem[]

  @@unique([agentId, batchId])
}

model SyncBatchItem {
  id           String      @id @default(cuid())
  syncBatchId  String
  agentEventId String?
  eventId      String
  status       String
  errorCode    String?
  errorMessage String?
  createdAt    DateTime    @default(now())
  syncBatch    SyncBatch   @relation(fields: [syncBatchId], references: [id])
  agentEvent   AgentEvent? @relation(fields: [agentEventId], references: [id])

  @@index([syncBatchId, status])
}

model AuditOccurrence {
  id         String   @id @default(cuid())
  unitId     String?
  type       String
  severity   String
  plate      String?
  ticketCode String?
  status     String
  comment    String?
  createdAt  DateTime @default(now())
  unit       Unit?    @relation(fields: [unitId], references: [id])
}

model KioskSession {
  id          String   @id @default(cuid())
  terminalId  String?
  ticketCode  String?
  status      String
  payload     Json?
  createdAt   DateTime @default(now())
}

model MobileDevice {
  id          String   @id @default(cuid())
  name        String
  identifier  String   @unique
  status      String
  lastSyncAt  DateTime?
}

model ValetRequest {
  id            String   @id @default(cuid())
  ticketCode    String?
  customerName  String
  plate         String
  status        String
  priority      String?
  attendant     String?
  etaMinutes    Int?
  createdAt     DateTime @default(now())
}

model FiscalConfig {
  id                String   @id @default(cuid())
  unitId            String
  municipality      String
  document          String
  municipalRegistry String?
  rpsSeries         String
  environment       String
  apiToken          String?
  unit              Unit     @relation(fields: [unitId], references: [id])
}

model Rps {
  id          String   @id @default(cuid())
  number      String   @unique
  customer    String
  amount      Decimal  @db.Decimal(10, 2)
  status      String
  createdAt   DateTime @default(now())
}

model Nfse {
  id          String   @id @default(cuid())
  number      String   @unique
  rpsNumber   String
  amount      Decimal  @db.Decimal(10, 2)
  status      String
  xmlUrl      String?
  pdfUrl      String?
  createdAt   DateTime @default(now())
}

model ReportConfig {
  id         String   @id @default(cuid())
  name       String
  type       String
  filters    Json?
  createdAt  DateTime @default(now())
}

model SystemLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  payload    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  unitId     String?
  title      String
  body       String
  channel    String
  readAt     DateTime?
  createdAt  DateTime @default(now())
  unit       Unit?    @relation(fields: [unitId], references: [id])
}

model InventoryItem {
  id         String   @id @default(cuid())
  name       String
  sku        String?  @unique
  quantity   Int      @default(0)
  unitCost   Decimal? @db.Decimal(10, 2)
}

model Supplier {
  id         String   @id @default(cuid())
  name       String
  document   String?
  email      String?
  phone      String?
}

model FinancialAccount {
  id         String   @id @default(cuid())
  name       String
  type       String
  balance    Decimal? @db.Decimal(12, 2)
}

model Receivable {
  id          String    @id @default(cuid())
  unitId      String?
  customerId  String?
  description String
  amount      Decimal   @db.Decimal(10, 2)
  dueDate     DateTime
  status      String
  unit        Unit?     @relation(fields: [unitId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
}

model Payable {
  id          String   @id @default(cuid())
  unitId      String?
  description String
  amount      Decimal  @db.Decimal(10, 2)
  dueDate     DateTime
  status      String
  unit        Unit?    @relation(fields: [unitId], references: [id])
}

model Incident {
  id          String   @id @default(cuid())
  unitId      String?
  type        String
  description String
  status      String
  createdAt   DateTime @default(now())
  unit        Unit?    @relation(fields: [unitId], references: [id])
}
